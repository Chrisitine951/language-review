    {
      "type": "de_grammar",
      "category": "case_nominativ",
      "rule": "德語定冠詞變格規則",
      "example": "Nominativ: der Mann; Akkusativ: den Mann; Dativ: dem Mann; Genitiv: des Mannes",
      "explanation": "德語定冠詞會根據名詞的性別、單複數以及在句子中的格位（Nominativ主格、Akkusativ受格、Dativ間接受格、Genitiv所有格）而變化。\n變格表：\nNominativ: der, die, das, die (plural)\nAkkusativ: den, die, das, die (plural)\nDativ: dem, der, dem, den (plural)\nGenitiv: des, der, des, der (plural)"
    },
    {
      "type": "de_grammar",
      "category": "case_dativ",
      "rule": "介系詞 in 的用法 (表示位置或方向)",
      "example": "Ich gehe in das Haus. / Ich wohne in dem Haus.",
      "explanation": "當介系詞 in 表示「在哪裡」（靜態位置）時，後面接 Dativ；當 in 表示「到哪裡」（動態方向）時，後面接 Akkusativ。"
    },
    {
      "type": "de_grammar",
      "category": "case_dativ",
      "rule": "介系詞 zu 總是接 Dativ",
      "example": "Wir fahren zum Arzt.",
      "explanation": "介系詞 zu 常與人名、機構或地點（通常是朝向某人或某地）連用，表示去...，其後名詞一律使用 Dativ (第三格)。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "介系詞與冠詞縮寫",
      "example": "zu dem = zum; zu der = zur; in das = ins",
      "explanation": "某些介系詞與定冠詞可以縮寫成一個詞，形成慣用語。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "A1 常見強變化動詞 (Vokalwechsel)",
      "example": "fahren (du fährst, er fährt); geben (du gibst, er gibt)",
      "explanation": "部分動詞在 du 和 er/sie/es 人稱時，詞幹母音會發生變化，如 a 變 ä (fahren, schlafen, laufen, tragen, halten)，e 變 i (geben, essen) 或 ie (sehen)。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "德語規則動詞詞尾變化",
      "example": "ich fahre; du fährst; er/sie/es fährt; wir fahren; ihr fahrt; sie/Sie fahren",
      "explanation": "德語規則動詞的詞尾變化遵循固定模式：ich (-e), du (-st), er/sie/es (-t), wir (-en), ihr (-t), sie/Sie (-en)。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "不規則動詞 sein 的變位",
      "example": "ich bin; du bist; er/sie/es ist; wir sind; ihr seid; sie/Sie sind",
      "explanation": "動詞 sein (是) 是不規則動詞，其變位需要特別記憶。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "名詞省略冠詞的用法",
      "example": "Ich bin Student.",
      "explanation": "在自我介紹職稱時（如 Ich bin Student），以及表示種類或一般性不可數名詞時，通常省略冠詞。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "不定冠詞後形容詞的詞尾變化 (陰性 Akkusativ)",
      "example": "Taipeh ist eine bekannte Stadt.",
      "explanation": "當不定冠詞後面接陰性名詞，且該名詞處於 Akkusativ (受格) 時，形容詞詞尾會加上 -e。"
    },
    {
      "type": "de_grammar",
      "category": "clause",
      "rule": "不定詞片語的詞序",
      "example": "Ich gehe mit meiner Mutter Gemüse kaufen.",
      "explanation": "在德語不定詞片語中，通常將受詞放在不定詞前面，即「先寫名詞(受詞)再寫動詞」。"
    },
    {
      "type": "de_grammar",
      "category": "case_dativ",
      "rule": "句子中人與物的格位分配 (間接受詞與直接受詞)",
      "example": "Ich gehe mit meiner Mutter Gemüse kaufen.",
      "explanation": "當一個句子中同時涉及人（通常為間接受詞）和事物（通常為直接受詞）時，人通常用 Dativ (第三格)，事物用 Akkusativ (第四格)。例如 `mit meiner Mutter` (Dativ) 和 `Gemüse` (Akkusativ)。"
    },
    {
      "type": "de_grammar",
      "category": "vocab_pattern",
      "rule": "前往國家的介系詞用法",
      "example": "Wir fahren nach Österreich. / Wir fahren in die Schweiz.",
      "explanation": "前往沒有定冠詞的國家使用 nach + Dativ (例如 Österreich)；前往有定冠詞的國家使用 in + Akkusativ (例如 die Schweiz)。"
    },
